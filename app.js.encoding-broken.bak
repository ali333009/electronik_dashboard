                <td><span class="badge ${b.isActive !== false ? 'bg-success-soft' : 'bg-secondary-soft'}">${b.isActive !== false ? 'ظ…ظپط¹ظ‘ظ„' : 'ظ…ط¹ط·ظ‘ظ„'}</span></td>
                <td>
                  <div class="d-flex gap-1">
                    <button class="btn btn-icon btn-outline-primary" data-act="edit" data-id="${esc(b.id)}" title="طھط¹ط¯ظٹظ„"><i class="bi bi-pencil"></i></button>
                    <button class="btn btn-icon btn-outline-${b.isActive !== false ? 'warning' : 'success'}" data-act="toggle" data-id="${esc(b.id)}" title="${b.isActive !== false ? 'طھط¹ط·ظٹظ„' : 'طھظپط¹ظٹظ„'}"><i class="bi bi-${b.isActive !== false ? 'pause' : 'play'}"></i></button>
                    <button class="btn btn-icon btn-outline-danger" data-act="del" data-id="${esc(b.id)}" title="ط­ط°ظپ"><i class="bi bi-trash"></i></button>
                  </div>
                </td>
