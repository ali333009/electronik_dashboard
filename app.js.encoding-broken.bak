  apiKey: '',                 // ط£ط¯ط®ظ„ API Key ظ…ظ† Cloudinary Dashboard
  apiSecret: '',              // ط£ط¯ط®ظ„ API Secret ظ…ظ† Cloudinary Dashboard â€” ظ„ط§ طھط´ط§ط±ظƒظ‡ ط£ط¨ط¯ط§ظ‹ ظپظٹ ط§ظ„ظ€ client
};

/* =========================================================
   ط¥ط±ط³ط§ظ„ ط§ظ„ط¥ط´ط¹ط§ط±ط§طھ ط¹ط¨ط± Firebase Cloud Function
   =========================================================
   âڑ ï¸ڈ  FCM HTTP API ظ„ط§ ظٹط¯ط¹ظ… CORS ظ…ظ† ط§ظ„ظ…طھطµظپط­.
   ط§ظ„ط­ظ„: ط§ط³طھط¯ط¹ط§ط، Cloud Function ط¹ط¨ط± httpsCallable() â€” 
   ظ‡ظٹ ط§ظ„ظ„ظٹ طھط±ط³ظ„ FCM ط¹ط¨ط± Admin SDK ط¨ط¯ظˆظ† ظ…ط´ط§ظƒظ„ CORS.
   =========================================================
   ط®ط·ظˆط© ظˆط­ط¯ط©: ط§ظ†ط´ط± ط¯ط§ظ„ط© sendNotification ظپظٹ functions/index.js
   (ط§ظ„ظ…ط­طھظˆظ‰ ظ…ظˆط¬ظˆط¯ طھط­طھ ظپظٹ طھط¹ظ„ظٹظ‚ "ظƒظˆط¯ ط§ظ„ظ€ Cloud Function")
   ========================================================= */

/**
 * ط¥ط±ط³ط§ظ„ ط¥ط´ط¹ط§ط± ط¹ط¨ط± Cloud Function
 * @param {string} title - ط¹ظ†ظˆط§ظ† ط§ظ„ط¥ط´ط¹ط§ط±
 * @param {string} body - ظ†طµ ط§ظ„ط¥ط´ط¹ط§ط±
 * @param {string} target - 'all' ط£ظˆ userId
 */
async function sendFCMNotification(title, body, target = 'all') {
  let token = null;
  if (target !== 'all') {
    const userSnap = await db.collection('users').doc(target).get();
    const userData = userSnap.exists ? userSnap.data() : {};
    token = userData.fcmToken || (userData.fcmTokens && userData.fcmTokens[0]);
    if (!token) throw new Error('ظ‡ط°ط§ ط§ظ„ظ…ط³طھط®ط¯ظ… ظ„ظٹط³ ظ„ط¯ظٹظ‡ FCM Token');
  }
  const fn = firebase.functions().httpsCallable('sendNotification');
  const result = await fn({ title, body, target: token || 'all' });
  return result.data;
}

/* =========================================================
   2) ط·ط¨ظ‚ط© ط§ظ„ط¨ظٹط§ظ†ط§طھ (Data Layer) â€” CRUD
     ========================================================= */

/**
 * ظ‚ط±ط§ط،ط© ط¬ظ…ظٹط¹ ظ…ط³طھظ†ط¯ط§طھ collection â€” ظٹظڈظپط¶ظ‘ظ„ ط§ط³طھط®ط¯ط§ظ… listPaginated ظ„ظ„ظ…ط¬ظ…ظˆط¹ط§طھ ط§ظ„ظƒط¨ظٹط±ط©
 * @param {string} coll - ط§ط³ظ… ط§ظ„ظ…ط¬ظ…ظˆط¹ط©
 * @returns {Promise<Array>}
 * 
 * ظٹظڈظˆطµظ‰ ط¨ط§ط³طھط®ط¯ط§ظ… listPaginated(coll, { limit, orderByField, startAfter })
 * ظ„ظ„ظ…ط¬ظ…ظˆط¹ط§طھ ط§ظ„ظƒط¨ظٹط±ط© (products, orders) ظ„طھط¬ظ†ط¨ ط¬ظ„ط¨ ط¬ظ…ظٹط¹ ط§ظ„ظ…ط³طھظ†ط¯ط§طھ ط¯ظپط¹ط© ظˆط§ط­ط¯ط©طŒ
 * ظ…ظ…ط§ ظٹظ‚ظ„ظ„ ط§ظ„طھظƒظ„ظپط© ظˆط²ظ…ظ† ط§ظ„ط§ط³طھط¬ط§ط¨ط©.
 */
async function list(coll) {
  try {
    const snap = await db.collection(coll).get();
    return snap.docs.map(d => ({ id: d.id, ...d.data() }));
  } catch (e) {
    throw wrapError(e);
  }
}

/**
 * ظ‚ط±ط§ط،ط© ظ…ط³طھظ†ط¯ط§طھ collection ظ…ط¹ pagination (server-side)
 * @param {string} coll - ط§ط³ظ… ط§ظ„ظ…ط¬ظ…ظˆط¹ط©
 * @param {Object} opts - ط®ظٹط§ط±ط§طھ pagination
 * @param {number} opts.limit - ط¹ط¯ط¯ ط§ظ„ظ…ط³طھظ†ط¯ط§طھ ط§ظ„ظ…ط·ظ„ظˆط¨ط© (default: 50)
 * @param {string} opts.orderByField - ط§ظ„ط­ظ‚ظ„ ظ„ظ„طھط±طھظٹط¨ (default: 'createdAt')
 * @param {*} opts.startAfter - ط¢ط®ط± ظ…ط³طھظ†ط¯ ظ…ط¹ط±ظˆظپ ظ„ظ„ط¨ط¯ط، ظ…ظ† ط¨ط¹ط¯ظ‡ (document snapshot or field value)
 * @param {string} opts.direction - ط§طھط¬ط§ظ‡ ط§ظ„طھط±طھظٹط¨ 'asc' ط£ظˆ 'desc' (default: 'desc')
 * @returns {Promise<{data: Array, lastDoc: any, hasMore: boolean}>}
 * 
 * ظ…ط«ط§ظ„:
 *   const page1 = await listPaginated('products', { limit: 25 });
 *   const page2 = await listPaginated('products', { startAfter: page1.lastDoc, limit: 25 });
 */
async function listPaginated(coll, { limit = 50, orderByField = 'createdAt', startAfter = null, direction = 'desc' } = {}) {
  try {
    let query = db.collection(coll)
      .orderBy(orderByField, direction)
      .limit(limit);

    if (startAfter) {
      query = query.startAfter(startAfter);
    }

    const snap = await query.get();
    const data = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    const lastDoc = snap.docs[snap.docs.length - 1] || null;
    const hasMore = snap.docs.length === limit;

    return { data, lastDoc, hasMore };
  } catch (e) {
    throw wrapError(e);
  }
}

/**
 * ظ‚ط±ط§ط،ط© ط¬ظ…ظٹط¹ ط§ظ„ظ…ط³طھط®ط¯ظ…ظٹظ† (collection = 'users')
 * @returns {Promise<Array>}
 */
async function listUsers() {
  try {
    const snap = await db.collection('users').get();
    return snap.docs.map(d => ({ id: d.id, uid: d.id, ...d.data() }));
  } catch (e) {
    throw wrapError(e);
  }
}

/**
 * ظ‚ط±ط§ط،ط© ط¬ظ…ظٹط¹ ط§ظ„طھظ‚ظٹظٹظ…ط§طھ ظ…ظ† ظƒظ„ ط§ظ„ظ…ظ†طھط¬ط§طھ (collectionGroup)
 * @returns {Promise<Array>}
 */
async function listReviews() {
  try {
    const snap = await db.collectionGroup('reviews').get();
    return snap.docs.map(d => ({ id: d.id, _path: d.ref.path, ...d.data() }));
  } catch (e) {
    throw wrapError(e);
  }
}

/**
 * ط¥ط¶ط§ظپط© ظ…ط³طھظ†ط¯ ط¬ط¯ظٹط¯
 * @param {string} coll - ط§ط³ظ… ط§ظ„ظ…ط¬ظ…ظˆط¹ط©
 * @param {Object} data - ط§ظ„ط¨ظٹط§ظ†ط§طھ
 * @returns {Promise<string>} - ظ…ط¹ط±ظ‘ظپ ط§ظ„ظ…ط³طھظ†ط¯ ط§ظ„ط¬ط¯ظٹط¯
 */
async function add(coll, data) {
  try {
    const ref = db.collection(coll).doc();
    await ref.set({
      id: ref.id,
      ...data,
      createdAt: serverTS(),
      updatedAt: serverTS(),
    });
    return ref.id;
  } catch (e) {
    throw wrapError(e);
  }
}

/**
 * ط¥ط¶ط§ظپط© ظ…ط³طھظ†ط¯ ط¨ظ…ط¹ط±ظ‘ظپ ظ…ط­ط¯ط¯
 * @param {string} coll - ط§ط³ظ… ط§ظ„ظ…ط¬ظ…ظˆط¹ط©
 * @param {string} id - ط§ظ„ظ…ط¹ط±ظ‘ظپ
 * @param {Object} data - ط§ظ„ط¨ظٹط§ظ†ط§طھ
 */
async function addWithId(coll, id, data) {
  try {
    await db.collection(coll).doc(id).set({
      id: id,
      ...data,
      createdAt: serverTS(),
      updatedAt: serverTS(),
    });
  } catch (e) {
    throw wrapError(e);
  }
}

/**
 * طھط­ط¯ظٹط« ظ…ط³طھظ†ط¯
 * @param {string} coll - ط§ط³ظ… ط§ظ„ظ…ط¬ظ…ظˆط¹ط©
 * @param {string} id - ط§ظ„ظ…ط¹ط±ظ‘ظپ
 * @param {Object} data - ط§ظ„ط¨ظٹط§ظ†ط§طھ ط§ظ„ظ…ظڈط­ط¯ظ‘ط«ط©
 */
async function update(coll, id, data) {
  try {
    await db.collection(coll).doc(id).update({
      id: id,
      ...data,
      updatedAt: serverTS(),
    });
  } catch (e) {
    throw wrapError(e);
  }
}

/**
 * ط­ط°ظپ ظ…ط³طھظ†ط¯
 * @param {string} coll - ط§ط³ظ… ط§ظ„ظ…ط¬ظ…ظˆط¹ط©
 * @param {string} id - ط§ظ„ظ…ط¹ط±ظ‘ظپ
 */
async function remove(coll, id) {
  try {
    await db.collection(coll).doc(id).delete();
  } catch (e) {
    throw wrapError(e);
  }
}

/**
 * ط­ط°ظپ طھظ‚ظٹظٹظ… (ط¯ط§ط®ظ„ subcollection)
 * @param {Object} rev - ط§ظ„طھظ‚ظٹظٹظ… ظ…ط¹ _path
 */
async function removeReview(rev) {
  try {
    await db.doc(rev._path).delete();
  } catch (e) {
    throw wrapError(e);
  }
}

/**
 * طھط­ظˆظٹظ„ ط£ط®ط·ط§ط، Firebase ط¥ظ„ظ‰ ط±ط³ط§ط¦ظ„ ط¹ط±ط¨ظٹط© ظˆط§ط¶ط­ط©
 */
function wrapError(e) {
  if (e.code === 'permission-denied') {
    return new Error('ظ„ظٹط³ ظ„ط¯ظٹظƒ طµظ„ط§ط­ظٹط©. طھط£ظƒط¯ ظ…ظ† ط£ظ† ط­ط³ط§ط¨ظƒ ط£ط¯ظ…ظ† (isAdmin: true ظپظٹ Firestore).');
  }
  if (e.code === 'unavailable') {
    return new Error('طھط¹ط°ظ‘ط± ط§ظ„ط§طھطµط§ظ„ ط¨ظ€ Firebase. طھط­ظ‚ظ‚ ظ…ظ† ط§ظ„ط¥ظ†طھط±ظ†طھ.');
  }
  return e;
}

/* =========================================================
   ط°ط§ظƒط±ط© ظ…ط¤ظ‚طھط© ظ„ظ„ط¨ظٹط§ظ†ط§طھ (Cache)
   ========================================================= */

const CACHE = {
  products: [],
  categories: [],
  orders: [],
  customers: [],
  banners: [],
  reviews: [],
  coupons: [],
  notifications: [],
  settings: {},
};

/**
 * طھط­ظ…ظٹظ„ ظƒظ„ ط§ظ„ط¨ظٹط§ظ†ط§طھ ظ…ظ† Firestore ظ…ط±ط© ظˆط§ط­ط¯ط©
 * ظ…ظ„ط§ط­ط¸ط©: ط§ظ„ظ…ظ†طھط¬ط§طھ ظˆط§ظ„ط·ظ„ط¨ط§طھ ظٹطھظ… ط¬ظ„ط¨ظ‡ط§ ط¹ط¨ط± listPaginated ظ„طھظ‚ظ„ظٹظ„ ط§ظ„طھظƒظ„ظپط©.
 * ط¥ط°ط§ ظƒط§ظ† ط§ظ„ط¹ط¯ط¯ ط§ظ„ظƒظ„ظٹ ظ…ط·ظ„ظˆط¨ط§ظ‹طŒ ط§ط³طھط®ط¯ظ… list() ط§ظ„ط¹ط§ط¯ظٹط© ط£ظˆ ط²ظگط¯ limit.
 */
async function loadAllData() {
  const [productsRes, categories, ordersRes, customers, banners, reviews, coupons, settings] = await Promise.all([
    listPaginated('products', { limit: 999, orderByField: 'createdAt' }).catch(() => ({ data: [], lastDoc: null, hasMore: false })),
    list('categories').catch(() => []),
    listPaginated('orders', { limit: 999, orderByField: 'createdAt' }).catch(() => ({ data: [], lastDoc: null, hasMore: false })),
    listUsers().catch(() => []),
    list('banners').catch(() => []),
    listReviews().catch(() => []),
    list('promoCodes').catch(() => []),
    loadSettings().catch(() => ({})),
  ]);
  const products = productsRes.data || [];
  const orders = ordersRes.data || [];
  Object.assign(CACHE, { products, categories, orders, customers, banners, reviews, coupons, settings });
  // طھط­ط°ظٹط± ظپظٹ ط­ط§ظ„ ظˆط¬ظˆط¯ ط¨ظٹط§ظ†ط§طھ ط£ظƒط«ط± ظ…ظ† limit ظ„ظ„ظ€ pagination
  if (productsRes.hasMore) {
    console.warn('âڑ ï¸ڈ  طھظˆط¬ط¯ ظ…ظ†طھط¬ط§طھ ط¥ط¶ط§ظپظٹط© ظ„ظ… ظٹطھظ… طھط­ظ…ظٹظ„ظ‡ط§ (ط£ظƒط«ط± ظ…ظ† 999). ط§ط³طھط®ط¯ظ… listPaginated ظ…ط¹ startAfter ظ„ط¬ظ„ط¨ ط§ظ„ط¨ط§ظ‚ظٹ.');
  }
  if (ordersRes.hasMore) {
    console.warn('âڑ ï¸ڈ  طھظˆط¬ط¯ ط·ظ„ط¨ط§طھ ط¥ط¶ط§ظپظٹط© ظ„ظ… ظٹطھظ… طھط­ظ…ظٹظ„ظ‡ط§. ط§ط³طھط®ط¯ظ… listPaginated ظ…ط¹ startAfter ظ„ط¬ظ„ط¨ ط§ظ„ط¨ط§ظ‚ظٹ.');
  }
}

/**
 * طھط­ظ…ظٹظ„ ط¥ط¹ط¯ط§ط¯ط§طھ ط§ظ„ظ…طھط¬ط± ظ…ظ† collection `_meta/store_config`
 */
async function loadSettings() {
  const [storeSnap, shippingSnap] = await Promise.all([
    db.collection('_meta').doc('store_config').get(),
    db.collection('settings').doc('shipping').get(),
  ]);
  const store = storeSnap.exists ? storeSnap.data() : {};
  const shipping = shippingSnap.exists ? shippingSnap.data() : {};
  // ط¯ظ…ط¬ ط¥ط¹ط¯ط§ط¯ط§طھ ط§ظ„ط´ط­ظ† ظ…ظ† settings/shipping (ط§ظ„ظ…ط³ط§ط± ط§ظ„ط°ظٹ ظٹط³طھط®ط¯ظ…ظ‡ Flutter)
  CACHE.settings = {
    ...store,
    shippingFee: shipping.shippingCost ?? store.shippingFee ?? 0,
    freeShippingThreshold: shipping.freeShippingThreshold ?? store.freeShippingThreshold ?? 0,
  };
  return CACHE.settings;
}

/* =========================================================
   3) ط£ط¯ظˆط§طھ ظ…ط³ط§ط¹ط¯ط© ط¹ط§ظ…ط© (Helpers)
   ========================================================= */

/** ط§ط®طھطµط§ط± ظ„ظ€ querySelector */
function $(sel, parent = document) { return parent.querySelector(sel); }

/** ط§ط®طھطµط§ط± ظ„ظ€ querySelectorAll ظƒظ…طµظپظˆظپط© */
function $$(sel, parent = document) { return Array.from(parent.querySelectorAll(sel)); }

/** Escape HTML ظ„ظ…ظ†ط¹ XSS */
function esc(str) {
  if (str === null || str === undefined) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

/** طھط­ظˆظٹظ„ Firestore Timestamp / ط«ظˆط§ظ†ظٹ / طھط§ط±ظٹط® ط¥ظ„ظ‰ Date */
function toDate(v) {
  if (!v) return null;
  if (typeof v.toDate === 'function') return v.toDate();
  if (v.seconds) return new Date(v.seconds * 1000);
  return new Date(v);
}

/** طھظ†ط³ظٹظ‚ ط§ظ„ط£ط±ظ‚ط§ظ… ط¨ط£ط±ظ‚ط§ظ… ط¥ظ†ط¬ظ„ظٹط²ظٹط© */
function formatNumber(n) {
  if (n === null || n === undefined || isNaN(n)) return '0';
  return Number(n).toLocaleString('en-US');
}

/** طھظ†ط³ظٹظ‚ ط§ظ„ط¹ظ…ظ„ط© (ط¯ظٹظ†ط§ط± ظƒظˆظٹطھظٹ ط§ظپطھط±ط§ط¶ظٹظ‹ط§) */
function formatCurrency(amount, currency = 'KD') {
  if (amount === null || amount === undefined || isNaN(amount)) return `0 ${currency}`;
  return `${Number(amount).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ${currency}`;
}

/** ط§ط³طھط®ط±ط§ط¬ ط§ظ„ط­ط±ظˆظپ ط§ظ„ط£ظˆظ„ظ‰ ظ…ظ† ط§ظ„ط§ط³ظ… */
function getInitials(name) {
  if (!name || typeof name !== 'string') return '?';
  const parts = name.trim().split(/\s+/);
  if (parts.length === 1) return parts[0].charAt(0).toUpperCase();
  return parts[0].charAt(0).toUpperCase() + parts[parts.length - 1].charAt(0).toUpperCase();
}

/** ظ‚طµ ظƒظˆط¯ ط§ظ„ط¯ظˆظ„ط© ظ…ظ† ط±ظ‚ظ… ط§ظ„ظ‡ط§طھظپ */
function normalizePhone(phone) {
  if (!phone || typeof phone !== 'string') return phone || '';
  let p = phone.trim().replace(/[\s\-()]/g, '');
  if (p.startsWith('00')) p = '+' + p.slice(2);
  if (!p.startsWith('+')) return p;
  const codes = ['+966','+971','+974','+973','+965','+968','+962','+961','+963','+967','+970','+972','+218','+216','+213','+212','+222','+249','+252','+253','+20'];
  for (const code of codes) { if (p.startsWith(code)) return '0' + p.slice(code.length); }
  return phone.trim();
}

/** طھظ†ط³ظٹظ‚ ط§ظ„طھط§ط±ظٹط® */
function formatDate(date, withTime = false) {
  const d = toDate(date);
  if (!d || isNaN(d.getTime())) return 'â€”';
  const opts = { year: 'numeric', month: 'short', day: 'numeric' };
  if (withTime) { opts.hour = '2-digit'; opts.minute = '2-digit'; }
  return d.toLocaleDateString('ar-EG-u-nu-latn', opts);
}

/** ط§ظ„ظˆظ‚طھ ط§ظ„ظ†ط³ط¨ظٹ (ظ…ظ†ط° ظƒط°ط§) */
function timeAgo(date) {
  const d = toDate(date);
  if (!d) return 'â€”';
  const s = Math.floor((Date.now() - d.getTime()) / 1000);
  if (s < 60) return 'ط§ظ„ط¢ظ†';
  const m = Math.floor(s / 60); if (m < 60) return `ظ…ظ†ط° ${m} ط¯ظ‚ظٹظ‚ط©`;
  const h = Math.floor(m / 60); if (h < 24) return `ظ…ظ†ط° ${h} ط³ط§ط¹ط©`;
  const d2 = Math.floor(h / 24); if (d2 < 30) return `ظ…ظ†ط° ${d2} ظٹظˆظ…`;
  const mo = Math.floor(d2 / 30); if (mo < 12) return `ظ…ظ†ط° ${mo} ط´ظ‡ط±`;
  return `ظ…ظ†ط° ${Math.floor(mo / 12)} ط³ظ†ط©`;
}

/** طھظ†ط³ظٹظ‚ ط­ط¬ظ… ط§ظ„ظ…ظ„ظپ */
function formatBytes(bytes) {
  if (!bytes) return '0 B';
  const k = 1024;
  const sizes = ['B', 'KB', 'MB', 'GB'];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
}

/**
 * طھط·ط¨ظٹط¹ ط§ظ„ظ†طµ ط§ظ„ط¹ط±ط¨ظٹ ظ„ظ„ط¨ط­ط« ط§ظ„ظ…ط±ظ†
 * - طھظˆط­ظٹط¯ ط§ظ„ظ‡ظ…ط²ط§طھ (ط£/ط¥/ط¢ â†’ ط§)
 * - طھظˆط­ظٹط¯ ط§ظ„طھط§ط، ط§ظ„ظ…ط±ط¨ظˆط·ط© (ط© â†’ ظ‡ظ€)
 * - طھظˆط­ظٹط¯ ط§ظ„ط£ظ„ظپ ط§ظ„ظ…ظ‚طµظˆط±ط© (ظ‰ â†’ ظٹ)
 * - ط¥ط²ط§ظ„ط© ط§ظ„طھط´ظƒظٹظ„
 * - ط¥ط²ط§ظ„ط© ظ„ط§ط­ظ‚ط§طھ ط§ظ„ط¬ظ…ط¹ (ط§طھ/ظˆظ†/ظٹظ†/ط©/ظ‡ظ€/طھ) ظ…ظ† ظ†ظ‡ط§ظٹط© ظƒظ„ ظƒظ„ظ…ط©
 * - ط¥ط²ط§ظ„ط© "ط§ظ„" ط§ظ„طھط¹ط±ظٹظپ
 */
function normalizeArabic(text) {
  if (!text) return '';
  return String(text)
    .replace(/[\u064B-\u065F\u0670]/g, '')   // ط§ظ„طھط´ظƒظٹظ„
    .replace(/[ط£ط¥ط¢]/g, 'ط§')                    // ط§ظ„ظ‡ظ…ط²ط§طھ
    .replace(/ط©/g, 'ظ‡')                        // ط§ظ„طھط§ط، ط§ظ„ظ…ط±ط¨ظˆط·ط©
    .replace(/ظ‰/g, 'ظٹ')                        // ط§ظ„ط£ظ„ظپ ط§ظ„ظ…ظ‚طµظˆط±ط©
    .replace(/\s+/g, ' ').trim()
    .split(' ')
    .map(word => {
      if (word.length <= 3) return word;
      return word
        .replace(/(ظٹط§طھ|ط§طھ|ظˆظ†|ظٹظ†)$/g, '')       // ط¬ظ…ط¹
        .replace(/(ط§ظ‡|ظˆظ‡)$/g, '')              // ظ„ط§ط­ظ‚ط§طھ ظ†ط§ط¯ط±ط©
        .replace(/ظ‡$/g, '')                    // طھط§ط، ظ…ط±ط¨ظˆط·ط© ظ…ط·ط¨ظژظ‘ط¹ط©
        .replace(/طھ$/g, '')                    // طھط§ط، ظ…ظپطھظˆط­ط©
        .replace(/^(ط§ظ„)/g, '');                // "ط§ظ„" ط§ظ„طھط¹ط±ظٹظپ
    })
    .join(' ')
    .toLowerCase()
    .trim()
    .replace(/\s+/g, ' ');
}

/**
 * ط¨ط­ط« ط¹ط±ط¨ظٹ ظ…ط±ظ†
 * @param {string} haystack - ط§ظ„ظ†طµ ط§ظ„ظ…ط±ط§ط¯ ط§ظ„ط¨ط­ط« ظپظٹظ‡
 * @param {string} needle - ظƒظ„ظ…ط© ط§ظ„ط¨ط­ط«
 * @returns {boolean}
 */
function arabicSearch(haystack, needle) {
  if (!needle) return true;
  const h = normalizeArabic(haystack);
  const n = normalizeArabic(needle);
  if (!n) return true;
  if (!h) return false;
  if (h.includes(n)) return true;
  const words = n.split(' ').filter(w => w.length > 1);
  if (words.length > 1) return words.some(w => h.includes(w));
  const haystackWords = h.split(' ').filter(w => w.length > 0);
  return haystackWords.some(w => w.startsWith(n) || w.includes(n));
}

/**
 * طھظˆظ„ظٹط¯ searchKeywords ظ„ظ„ط¨ط­ط« ط§ظ„ط°ظƒظٹ ظپظٹ طھط·ط¨ظٹظ‚ Flutter
 */
function generateSearchKeywords(nameAr = '', nameEn = '', tags = []) {
  const keywords = new Set();
  if (nameAr) keywords.add(nameAr.toLowerCase().trim());
  if (nameEn) keywords.add(nameEn.toLowerCase().trim());
  (nameAr || '').split(/\s+/).forEach(w => { if (w.length > 1) keywords.add(w.toLowerCase()); });
  (nameEn || '').split(/\s+/).forEach(w => { if (w.length > 1) keywords.add(w.toLowerCase()); });
  (tags || []).forEach(t => { if (t) keywords.add(t.toLowerCase().trim()); });
  // ط¥ط¶ط§ظپط© prefixes ظ„ظ„ط¨ط­ط« ط§ظ„طھط¯ط±ظٹط¬ظٹ
  [...keywords].forEach(kw => {
    for (let i = 3; i < Math.min(kw.length, 10); i++) {
      keywords.add(kw.substring(0, i));
    }
  });
  return [...keywords].filter(Boolean);
}

/** ط¹ط±ط¶ ط¥ط´ط¹ط§ط± Toast */
function showToast(message, type = 'info', duration = 3500) {
  const container = $('#toast-container');
  if (!container) { alert(message); return; }
  const iconMap = {
    success: 'bi-check-circle-fill',
    error: 'bi-x-circle-fill',
    warning: 'bi-exclamation-triangle-fill',
    info: 'bi-info-circle-fill',
  };
  const titleMap = { success: 'طھظ… ط¨ظ†ط¬ط§ط­', error: 'ط®ط·ط£', warning: 'طھظ†ط¨ظٹظ‡', info: 'ظ…ط¹ظ„ظˆظ…ط©' };
  const el = document.createElement('div');
  el.className = `toast toast-${type} show`;
  el.setAttribute('role', 'alert');
  el.innerHTML = `
    <div class="toast-header">
      <i class="bi ${iconMap[type]} me-2"></i>
      <strong class="me-auto">${titleMap[type]}</strong>
      <small class="text-muted">${new Date().toLocaleTimeString('ar-EG-u-nu-latn', { hour: '2-digit', minute: '2-digit' })}</small>
      <button type="button" class="btn-close btn-close-white me-0" aria-label="ط¥ط؛ظ„ط§ظ‚"></button>
    </div>
    <div class="toast-body">${esc(message)}</div>
  `;
  el.querySelector('.btn-close').addEventListener('click', () => {
    el.classList.remove('show');
    setTimeout(() => el.remove(), 300);
  });
  container.appendChild(el);
  setTimeout(() => {
    el.classList.remove('show');
    setTimeout(() => el.remove(), 300);
  }, duration);
}

/** Modal طھط£ظƒظٹط¯ ط§ظ„ط¹ظ…ظ„ظٹط© (ظٹظڈط±ط¬ط¹ Promise<boolean>) */
function confirmAction(message = 'ظ‡ظ„ ط£ظ†طھ ظ…طھط£ظƒط¯طں', title = 'طھط£ظƒظٹط¯ ط§ظ„ط¹ظ…ظ„ظٹط©', confirmText = 'طھط£ظƒظٹط¯', confirmType = 'danger') {
  return new Promise((resolve) => {
    const modalId = 'confirm-modal-' + Date.now() + '-' + Math.random().toString(36).substring(2, 8);
    const wrap = document.createElement('div');
    wrap.innerHTML = `
      <div class="modal fade" id="${modalId}" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-warning me-2"></i>${esc(title)}</h5>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body"><p class="mb-0">${esc(message)}</p></div>
            <div class="modal-footer">
              <button type="button" class="btn btn-light" data-bs-dismiss="modal">ط¥ظ„ط؛ط§ط،</button>
              <button type="button" class="btn btn-${confirmType}" id="${modalId}-ok">${esc(confirmText)}</button>
            </div>
          </div>
        </div>
      </div>
    `;
    document.body.appendChild(wrap);
    const modal = new bootstrap.Modal(wrap.querySelector('.modal'));
    let resolved = false;
    modal.show();
    wrap.querySelector(`#${modalId}-ok`).addEventListener('click', () => {
      resolved = true;
      modal.hide();
      resolve(true);
    });
    wrap.querySelector('.modal').addEventListener('hidden.bs.modal', () => {
      wrap.remove();
      if (!resolved) resolve(false);
    });
  });
}

/** ط¬ظ…ط¹ ط¨ظٹط§ظ†ط§طھ ط§ظ„ظ†ظ…ظˆط°ط¬ ظپظٹ ظƒط§ط¦ظ† */
function getFormData(form) {
  const data = {};
  form.querySelectorAll('input, select, textarea').forEach(el => {
    if (!el.name) return;
    if (el.type === 'checkbox') data[el.name] = el.checked;
    else if (el.type === 'radio') { if (el.checked) data[el.name] = el.value; }
    else if (el.type === 'number') data[el.name] = el.value === '' ? null : Number(el.value);
    else if (el.type !== 'file') data[el.name] = el.value;
  });
  return data;
}

/** ظ…ظ„ط، ط§ظ„ظ†ظ…ظˆط°ط¬ ط¨ظ‚ظٹظ… */
function setFormData(form, data) {
  form.querySelectorAll('input, select, textarea').forEach(el => {
    if (!el.name || !(el.name in data)) return;
    if (el.type === 'checkbox') el.checked = !!data[el.name];
    else if (el.type === 'radio') el.checked = String(el.value) === String(data[el.name]);
    else if (el.type === 'date' && data[el.name]) {
      const d = toDate(data[el.name]);
      el.value = d ? d.toISOString().split('T')[0] : '';
    } else el.value = data[el.name] ?? '';
  });
}

/** ظپطھط­ Modal ط¹ط§ظ… */
function openModal({ id, title, bodyHTML, submitText = 'ط­ظپط¸', submitType = 'primary', large = false, onSubmit = null, onShown = null, cancelText = 'ط¥ظ„ط؛ط§ط،' }) {
  closeModal(id);
  const container = $('#modal-container');
  if (!container) return;
  const html = `
    <div class="modal fade" id="${id}" tabindex="-1">
      <div class="modal-dialog ${large ? 'modal-lg' : ''} modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">${title}</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">${bodyHTML}</div>
          <div class="modal-footer">
            <button type="button" class="btn btn-light" data-bs-dismiss="modal">${cancelText}</button>
            ${onSubmit ? `<button type="button" class="btn btn-${submitType}" id="${id}-submit"><span class="btn-text">${submitText}</span><span class="spinner-border spinner-border-sm d-none"></span></button>` : ''}
          </div>
        </div>
      </div>
    </div>
  `;
  container.insertAdjacentHTML('beforeend', html);
  const modalEl = container.querySelector(`#${id}`);
  const modal = new bootstrap.Modal(modalEl);
  modalEl.addEventListener('shown.bs.modal', () => { if (onShown) onShown(modalEl); });
  modalEl.addEventListener('hidden.bs.modal', () => { modalEl.remove(); });
  if (onSubmit) {
    const btn = modalEl.querySelector(`#${id}-submit`);
    btn.addEventListener('click', async () => {
      const txt = btn.querySelector('.btn-text');
      const sp = btn.querySelector('.spinner-border');
      txt.classList.add('d-none');
      sp.classList.remove('d-none');
      btn.disabled = true;
      try {
        const result = await onSubmit(modalEl);
        if (result !== false) modal.hide();
      } catch (e) {
        console.error('[Modal] ط®ط·ط£:', e);
        showToast(e.message || 'ط®ط·ط£', 'error');
      } finally {
        txt.classList.remove('d-none');
        sp.classList.add('d-none');
        btn.disabled = false;
      }
    });
  }
  modal.show();
}

/** ط¥ط؛ظ„ط§ظ‚ Modal */
function closeModal(id) {
  const el = document.getElementById(id);
  if (el) {
    const m = bootstrap.Modal.getInstance(el);
    if (m) m.hide();
    else el.remove();
  }
}

// ط§ظ„ط£ظ‚ط³ط§ظ… ط§ظ„طھط§ظ„ظٹط© طھظƒظ…ظ„ ظپظٹ ط§ظ„ظ…ظ„ظپ...

/* =========================================================
   4) ظ†ط¸ط§ظ… ط§ظ„ظ…طµط§ط¯ظ‚ط© (Auth)
   ========================================================= */

let currentAdmin = null;

/**
 * طھط³ط¬ظٹظ„ ط§ظ„ط¯ط®ظˆظ„ + ط§ظ„طھط­ظ‚ظ‚ ظ…ظ† طµظ„ط§ط­ظٹط© ط§ظ„ط£ط¯ظ…ظ†
 */
async function login(email, password) {
  const cred = await auth.signInWithEmailAndPassword(email, password);
  const snap = await db.collection('users').doc(cred.user.uid).get();
  const d = snap.exists ? snap.data() : {};
  if (!(d.isAdmin === true || d.role === 'admin')) {
    await auth.signOut();
    throw new Error('ظ‡ط°ط§ ط§ظ„ط­ط³ط§ط¨ ظ„ظٹط³ ظ„ط¯ظٹظ‡ طµظ„ط§ط­ظٹط© ط£ط¯ظ…ظ†');
  }
  currentAdmin = {
    uid: cred.user.uid,
    email: cred.user.email,
    displayName: d.displayName || d.email || email,
  };
  await startDashboard();
}

/** طھط³ط¬ظٹظ„ ط§ظ„ط®ط±ظˆط¬ */
function logout() {
  auth.signOut().then(() => {
    currentAdmin = null;
    location.reload();
  });
}

/** ط¹ط±ط¶ ط´ط§ط´ط© طھط³ط¬ظٹظ„ ط§ظ„ط¯ط®ظˆظ„ */
function showLoginView() {
  const pre = $('#preloader');
  if (pre) {
    pre.classList.add('hidden');
    pre.style.display = 'none';
  }
  $('#login-view')?.classList.remove('d-none');
  $('#app-shell')?.classList.add('d-none');
  attachLoginEvents();
}

/** ط±ط¨ط· ط£ط­ط¯ط§ط« ظ†ظ…ظˆط°ط¬ ط§ظ„ط¯ط®ظˆظ„ */
function attachLoginEvents() {
  const form = $('#login-form');
  if (!form || form.dataset.attached === 'true') return;
  form.dataset.attached = 'true';

  $('#toggle-password').addEventListener('click', () => {
    const inp = $('#login-password');
    const isPw = inp.type === 'password';
    inp.type = isPw ? 'text' : 'password';
    $('#toggle-password i').className = isPw ? 'bi bi-eye-slash' : 'bi bi-eye';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = $('#login-email').value.trim();
    const password = $('#login-password').value;
    const errBox = $('#login-error');
    const btn = $('#login-btn');
    const txt = btn.querySelector('.btn-text');
    const sp = btn.querySelector('.spinner-border');

    txt.textContent = 'ط¬ط§ط±ظٹ ط§ظ„طھط­ظ‚ظ‚...';
    sp.classList.remove('d-none');
    btn.disabled = true;
    errBox.classList.add('d-none');

    try {
      await login(email, password);
      showToast('ظ…ط±ط­ط¨ظ‹ط§ ط¨ظƒ ظپظٹ ظ„ظˆط­ط© ط§ظ„طھط­ظƒظ…', 'success');
    } catch (error) {
      console.error('[Login] ط®ط·ط£:', error);
      const map = {
        'auth/invalid-email': 'ط§ظ„ط¨ط±ظٹط¯ ط§ظ„ط¥ظ„ظƒطھط±ظˆظ†ظٹ ط؛ظٹط± طµط§ظ„ط­',
        'auth/user-disabled': 'طھظ… طھط¹ط·ظٹظ„ ظ‡ط°ط§ ط§ظ„ط­ط³ط§ط¨',
        'auth/user-not-found': 'ظ„ط§ ظٹظˆط¬ط¯ ط­ط³ط§ط¨ ط¨ظ‡ط°ط§ ط§ظ„ط¨ط±ظٹط¯',
        'auth/wrong-password': 'ظƒظ„ظ…ط© ط§ظ„ظ…ط±ظˆط± ط؛ظٹط± طµط­ظٹط­ط©',
        'auth/invalid-credential': 'ط¨ظٹط§ظ†ط§طھ ط§ظ„ط¯ط®ظˆظ„ ط؛ظٹط± طµط­ظٹط­ط©',
        'auth/too-many-requests': 'ظ…ط­ط§ظˆظ„ط§طھ ظƒط«ظٹط±ط© ظپط§ط´ظ„ط©. ط­ط§ظˆظ„ ظ„ط§ط­ظ‚ظ‹ط§',
        'auth/network-request-failed': 'طھط¹ط°ظ‘ط± ط§ظ„ط§طھطµط§ظ„ ط¨ط§ظ„ط®ط§ط¯ظ…',
        'auth/configuration-not-found': 'ط¥ط¹ط¯ط§ط¯ط§طھ Firebase ط؛ظٹط± ظ…ظƒطھظ…ظ„ط©',
        'auth/api-key-not-valid': 'ظ…ظپطھط§ط­ Firebase API ط؛ظٹط± طµط§ظ„ط­',
        'auth/api-key-not-valid.-please-pass-a-valid-api-key.': 'ظ…ظپطھط§ط­ Firebase API ط؛ظٹط± طµط§ظ„ط­',
        'auth/unauthorized-domain': 'ظ‡ط°ط§ ط§ظ„ظ†ط·ط§ظ‚ ط؛ظٹط± ظ…طµط±ظ‘ط­ ط¨ظ‡ ظپظٹ Firebase Console',
        'auth/operation-not-allowed': 'ط·ط±ظٹظ‚ط© طھط³ط¬ظٹظ„ ط§ظ„ط¯ط®ظˆظ„ ط؛ظٹط± ظ…ظپط¹ظ‘ظ„ط© ظپظٹ Firebase Console',
      };
      const msg = (error.code && map[error.code]) || error.message || 'طھط¹ط°ظ‘ط± طھط³ط¬ظٹظ„ ط§ظ„ط¯ط®ظˆظ„';
      errBox.textContent = msg;
      errBox.classList.remove('d-none');
    } finally {
      txt.textContent = 'طھط³ط¬ظٹظ„ ط§ظ„ط¯ط®ظˆظ„';
      sp.classList.add('d-none');
      btn.disabled = false;
    }
  });
}

/** ط¨ط¯ط، ظ„ظˆط­ط© ط§ظ„طھط­ظƒظ… ط¨ط¹ط¯ ط§ظ„طھط­ظ‚ظ‚ */
async function startDashboard() {
  $('#login-view')?.classList.add('d-none');
  const pre = $('#preloader');
  if (pre) {
    pre.classList.remove('hidden');
    pre.style.display = 'flex';
  }
  try {
    await loadAllData();
  } catch (e) {
    console.error('[loadAllData] ط®ط·ط£:', e);
    showToast('طھط¹ط°ظ‘ط± طھط­ظ…ظٹظ„ ط§ظ„ط¨ظٹط§ظ†ط§طھ: ' + e.message, 'error');
  }
  if (pre) {
    pre.classList.add('hidden');
    setTimeout(() => pre.remove(), 400);
  }
  $('#app-shell')?.classList.remove('d-none');
  renderSidebar();
  renderNavbar();
  const hash = window.location.hash.replace(/^#\/?/, '') || 'dashboard';
  const routeName = hash.split('/')[0];
  navigate(ROUTES[routeName] ? routeName : 'dashboard');
}

/* =========================================================
   5) ط§ظ„ظ€ Router + ط§ظ„طھظ†ظ‚ظ„
   ========================================================= */

const ROUTES = {};
let currentRoute = 'dashboard';

function registerRoute(name, render) { ROUTES[name] = render; }

/** ط§ظ„طھظ†ظ‚ظ„ ط¨ظٹظ† ط§ظ„طµظپط­ط§طھ */
function navigate(route) {
  if (!ROUTES[route]) route = 'dashboard';
  currentRoute = route;
  if (window.location.hash !== `#/${route}`) window.location.hash = `#/${route}`;
  highlightActiveNav(route);
  updateNavbarTitle(route);
  const main = $('#main-content');
  main.innerHTML = `<div class="empty-state"><div class="spinner-border text-primary"></div><p class="mt-3">ط¬ط§ط±ظٹ ط§ظ„طھط­ظ…ظٹظ„...</p></div>`;
  window.scrollTo({ top: 0, behavior: 'smooth' });
  try {
    ROUTES[route](main);
    main.classList.remove('view-enter');
    void main.offsetWidth;
    main.classList.add('view-enter');
  } catch (e) {
    console.error('[Router] ط®ط·ط£:', e);
    main.innerHTML = `<div class="empty-state"><i class="bi bi-exclamation-triangle text-danger"></i><h5>ط®ط·ط£ ظپظٹ ط§ظ„طھط­ظ…ظٹظ„</h5><p>${esc(e.message)}</p></div>`;
  }
}

/** ظ…ط¹ط§ظ„ط¬ طھط؛ظٹظٹط± ط§ظ„ظ€ hash */
function handleHashChange() {
  const hash = window.location.hash.replace(/^#\/?/, '') || 'dashboard';
  const routeName = hash.split('/')[0];
  if (ROUTES[routeName] && routeName !== currentRoute) navigate(routeName);
  else if (!ROUTES[routeName]) navigate('dashboard');
}

