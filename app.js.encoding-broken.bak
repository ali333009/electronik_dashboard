  $('#btn-save-settings').addEventListener('click', async () => {
    const wrap = $('#settings-wrap');
    const data = getFormData(wrap);
    try {
      await db.collection('_meta').doc('store_config').set({
        ...data,
        updatedAt: serverTS(),
      }, { merge: true });
      // ط­ظپط¸ ط¥ط¹ط¯ط§ط¯ط§طھ ط§ظ„ط´ط­ظ† ط£ظٹط¶ط§ظ‹ ظپظٹ ط§ظ„ظ…ط³ط§ط± ط§ظ„ط°ظٹ ظٹط³طھط®ط¯ظ…ظ‡ طھط·ط¨ظٹظ‚ Flutter
      await db.collection('settings').doc('shipping').set({
        shippingCost: Number(data.shippingFee) || 0,
        freeShippingThreshold: Number(data.freeShippingThreshold) || 0,
        updatedAt: serverTS(),
      }, { merge: true });
      CACHE.settings = { ...CACHE.settings, ...data };
      showToast('طھظ… ط­ظپط¸ ط§ظ„ط¥ط¹ط¯ط§ط¯ط§طھ ط¨ظ†ط¬ط§ط­', 'success');
    } catch (e) {
      showToast('ط®ط·ط£: ' + e.message, 'error');
    }
  });
}

/* =========================================================
   18) ط¯ظˆط§ظ„ ظ…ط³ط§ط¹ط¯ط© ط¥ط¶ط§ظپظٹط©
