function renderNotifications(container) {
  container.innerHTML = `
    <div class="page-header">
      <div>
        <h1>ط¥ط¯ط§ط±ط© ط§ظ„ط¥ط´ط¹ط§ط±ط§طھ</h1>
        <p class="page-subtitle">ط¥ط±ط³ط§ظ„ ط¥ط´ط¹ط§ط±ط§طھ ظ„ظ„ظ…ط³طھط®ط¯ظ…ظٹظ†</p>
      </div>
      <div class="page-actions">
        <button class="btn btn-primary" id="btn-send-notif"><i class="bi bi-send me-1"></i> ط¥ط±ط³ط§ظ„ ط¥ط´ط¹ط§ط± ط¬ط¯ظٹط¯</button>
      </div>
    </div>
    <div class="row g-3">
      <div class="col-lg-7">
        <div class="card">
          <div class="card-header"><i class="bi bi-clock-history me-2"></i> ط¢ط®ط± ط§ظ„ط¥ط´ط¹ط§ط±ط§طھ ط§ظ„ظ…ظڈط±ط³ظ„ط©</div>
          <div class="card-body p-0"><div id="notif-list" class="notification-list"></div></div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="card">
          <div class="card-header"><i class="bi bi-info-circle me-2"></i> ظ…ط¹ظ„ظˆظ…ط§طھ ط§ظ„ط¥ط±ط³ط§ظ„</div>
          <div class="card-body">
            <p class="mb-3 text-muted">ظٹظڈط±ط³ظ„ ط§ظ„ط¥ط´ط¹ط§ط± ط¹ط¨ط± <strong>Cloud Function</strong> â†’ <strong>FCM</strong> (ظٹط´طھط؛ظ„ ظپظٹ ط§ظ„ط®ظ„ظپظٹط©):</p>
            <ul class="text-muted small">
              <li class="mb-2"><i class="bi bi-check-circle text-success me-1"></i> ط§ظ„ط¥ط´ط¹ط§ط± ظٹظڈط­ظپط¸ ظپظٹ <code>notifications</code> collection</li>
              <li class="mb-2"><i class="bi bi-check-circle text-success me-1"></i> Cloud Function طھط±ط³ظ„ FCM ظ„ط¬ظ…ظٹط¹ ط§ظ„ظ…ط³طھط®ط¯ظ…ظٹظ† ط£ظˆ ظ„ظˆط§ط­ط¯</li>
              <li class="mb-2"><i class="bi bi-check-circle text-success me-1"></i> ظٹط´طھط؛ظ„ ظپظٹ ط§ظ„ط®ظ„ظپظٹط© (background) ظˆط§ظ„طھط·ط¨ظٹظ‚ ظ…ظ‚ظپظˆظ„ (terminated)</li>
            </ul>
            <hr>
            <p class="mb-2 small"><strong>طھط£ظƒط¯ ظ…ظ† ظ†ط´ط± Cloud Function:</strong></p>
            <pre style="font-size:0.72rem;background:var(--bg-surface-2);padding:0.65rem;border-radius:6px;direction:ltr;text-align:left;overflow-x:auto;white-space:pre-wrap;">
<code>// functions/index.js
const functions = require('firebase-functions');
const admin = require('firebase-admin');
admin.initializeApp();

exports.sendNotification = functions.https.onCall(async (data) => {
  const { title, body, target } = data;
  const message = {
    notification: { title, body, sound: 'default' },
    [target === 'all' ? 'topic' : 'token']: target === 'all' ? 'all' : target,
  };
  await admin.messaging().send(message);
  return { success: true };
});</code>
            </pre>
            <p class="mb-0 small text-warning"><i class="bi bi-info-circle me-1"></i> ط´ط؛ظ„ <code>firebase deploy --only functions</code> ط¨ط¹ط¯ ط¥ط¶ط§ظپط© ط§ظ„ظƒظˆط¯.</p>
          </div>
        </div>
      </div>
    </div>
  `;
  $('#btn-send-notif').addEventListener('click', openSendNotifModal);
  renderNotifList();
}

function renderNotifList() {
  const wrap = $('#notif-list');
  const list = [...(CACHE.notifications || [])]
    .sort((a, b) => (toDate(b.createdAt) || 0) - (toDate(a.createdAt) || 0));
  if (list.length === 0) {
    wrap.innerHTML = `<div class="empty-state"><i class="bi bi-bell-slash"></i><h5>ظ„ط§ طھظˆط¬ط¯ ط¥ط´ط¹ط§ط±ط§طھ ظ…ط±ط³ظ„ط©</h5></div>`;
    return;
  }
  wrap.innerHTML = list.map(n => `
    <div class="notif-item">
      <div class="notif-icon ${n.audience === 'all' ? 'bg-accent-soft' : 'bg-info-soft'}" style="color:${n.audience === 'all' ? 'var(--color-accent)' : 'var(--color-info)'};">
        <i class="bi bi-${n.audience === 'all' ? 'people' : 'person'}"></i>
      </div>
      <div class="flex-grow-1">
        <div class="d-flex justify-content-between">
          <strong>${esc(n.title)}</strong>
          <small class="text-muted">${formatDate(n.createdAt, true)}</small>
        </div>
        <p class="mb-1 text-muted">${esc(n.body || '')}</p>
        <small class="text-muted">
          <i class="bi bi-check-circle text-success"></i>
          ${n.status === 'sent' ? 'طھظ… ط§ظ„ط¥ط±ط³ط§ظ„' : 'ظ‚ظٹط¯ ط§ظ„ط¥ط±ط³ط§ظ„'}
          ${n.audience === 'all' ? 'آ· ظ„ط¬ظ…ظٹط¹ ط§ظ„ظ…ط³طھط®ط¯ظ…ظٹظ†' : 'آ· ظ„ظ…ط³طھط®ط¯ظ… ظ…ط­ط¯ط¯'}
        </small>
      </div>
    </div>
  `).join('');
}

function openSendNotifModal() {
  const bodyHTML = `
    <form id="notif-form">
      <div class="mb-3">
        <label class="form-label">ط§ظ„ظ…ط³طھظ‡ط¯ظپظˆظ† <span class="text-danger">*</span></label>
        <select class="form-select" name="audience" id="audience-sel">
          <option value="all">ط¬ظ…ظٹط¹ ط§ظ„ظ…ط³طھط®ط¯ظ…ظٹظ†</option>
          <option value="specific">ظ…ط³طھط®ط¯ظ… ظ…ط­ط¯ط¯</option>
        </select>
      </div>
      <div class="mb-3 d-none" id="user-field">
        <label class="form-label">ط§ط®طھط± ط§ظ„ظ…ط³طھط®ط¯ظ…</label>
        <select class="form-select" name="targetUserId" id="user-sel">
          <option value="">â€” ط§ط®طھط± ظ…ط³طھط®ط¯ظ… â€”</option>
          ${CACHE.customers.map(c => `<option value="${esc(c.uid)}">${esc(c.displayName || 'ط¹ظ…ظٹظ„')} (${esc(c.email || 'â€”')})</option>`).join('')}
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label">ط¹ظ†ظˆط§ظ† ط§ظ„ط¥ط´ط¹ط§ط± <span class="text-danger">*</span></label>
        <input type="text" class="form-control" name="title" required placeholder="ظ…ط«ط§ظ„: ط¹ط±ط¶ ط®ط§طµ ظ„ظ…ط¯ط© 24 ط³ط§ط¹ط©!" />
      </div>
      <div class="mb-3">
        <label class="form-label">ظ†طµ ط§ظ„ط¥ط´ط¹ط§ط± <span class="text-danger">*</span></label>
        <textarea class="form-control" name="body" rows="4" required placeholder="ط§ظƒطھط¨ ظ†طµ ط§ظ„ط¥ط´ط¹ط§ط± ظ‡ظ†ط§..."></textarea>
      </div>
      <div class="alert alert-info" style="background:var(--color-info-soft);border-color:var(--color-info);color:var(--color-info);">
        <i class="bi bi-info-circle me-1"></i>
        ط³ظٹطھظ… ط¥ط±ط³ط§ظ„ ط§ظ„ط¥ط´ط¹ط§ط± ظپظˆط±ط§ظ‹ ط¹ط¨ط± FCM + ط­ظپط¸ظ‡ ظپظٹ ظ‚ط§ط¹ط¯ط© ط§ظ„ط¨ظٹط§ظ†ط§طھ.
      </div>
    </form>
  `;
  closeModal('notif-modal');
  openModal({
    id: 'notif-modal',
    title: 'ط¥ط±ط³ط§ظ„ ط¥ط´ط¹ط§ط± ط¬ط¯ظٹط¯',
    bodyHTML,
    submitText: 'ط¥ط±ط³ط§ظ„ ط§ظ„ط¥ط´ط¹ط§ط±',
    onSubmit: async (modalEl) => {
      const form = modalEl.querySelector('#notif-form');
      if (!form.checkValidity()) { form.reportValidity(); return false; }
      const data = getFormData(form);
      if (data.audience === 'specific' && !data.targetUserId) {
        showToast('ط§ط®طھط± ظ…ط³طھط®ط¯ظ…ظ‹ط§ ظ…ط­ط¯ط¯ظ‹ط§', 'error');
        return false;
      }
      const payload = {
        title: data.title,
        body: data.body,
        audience: data.audience,
        targetUserId: data.audience === 'specific' ? data.targetUserId : null,
        status: 'sent',
      };
      try {
        // ط¥ط±ط³ط§ظ„ FCM ظپظˆط±ظٹ
        showToast('ط¬ط§ط±ظٹ ط¥ط±ط³ط§ظ„ ط§ظ„ط¥ط´ط¹ط§ط±...', 'info', 2000);
        if (data.audience === 'all') {
          await sendFCMNotification(data.title, data.body, 'all');
        } else {
          await sendFCMNotification(data.title, data.body, data.targetUserId);
        }
        // ط­ظپط¸ ط§ظ„ط¥ط´ط¹ط§ط± ظپظٹ ظ‚ط§ط¹ط¯ط© ط§ظ„ط¨ظٹط§ظ†ط§طھ
        const newId = await add('notifications', payload);
        if (!CACHE.notifications) CACHE.notifications = [];
        CACHE.notifications.push({ id: newId, ...payload, createdAt: new Date() });
        showToast('طھظ… ط¥ط±ط³ط§ظ„ ط§ظ„ط¥ط´ط¹ط§ط± ط¨ظ†ط¬ط§ط­', 'success');
        renderNotifList();
        return true;
      } catch (e) { showToast('ط®ط·ط£: ' + e.message, 'error'); return false; }
    },
    onShown: (modalEl) => {
      const audSel = modalEl.querySelector('#audience-sel');
      const userField = modalEl.querySelector('#user-field');
      audSel.addEventListener('change', () => {
        if (audSel.value === 'specific') {
          userField.classList.remove('d-none');
          userField.querySelector('select').required = true;
        } else {
          userField.classList.add('d-none');
          userField.querySelector('select').required = false;
        }
      });
    },
  });
}

