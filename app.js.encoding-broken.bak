        </div>
        <div class="col-md-4">
          <div class="mb-3">
            <label class="form-label">ظ…ط¹ط±ظ‘ظپ ط§ظ„ظ‡ط¯ظپ</label>
            <input type="text" class="form-control" name="targetId" dir="ltr" placeholder="categoryId ط£ظˆ productId ط£ظˆ URL" />
          </div>
        </div>
        <div class="col-md-2">
          <div class="mb-3">
            <label class="form-label">ط§ظ„ظ…ظ†ط·ظ‚ط©</label>
            <select class="form-select" name="zone">
              <option value="header">ط±ط£ط³ ط§ظ„طµظپط­ط©</option>
              <option value="bottom">ط£ط³ظپظ„ ط§ظ„طµظپط­ط©</option>
            </select>
            <small class="text-muted">ط§ط®طھط± ظ…ظƒط§ظ† ط¸ظ‡ظˆط± ط§ظ„ط¨ط§ظ†ط± ظپظٹ ط§ظ„طھط·ط¨ظٹظ‚</small>
          </div>
        </div>
        <div class="col-md-2"><div class="mb-3"><label class="form-label">ط§ظ„طھط±طھظٹط¨</label><input type="number" class="form-control" name="order" min="0" value="0" /></div></div>
        <div class="col-md-2">
          <div class="mb-3">
            <label class="form-label">ط§ظ„ط­ط§ظ„ط©</label>
            <div class="form-check form-switch mt-2">
              <input class="form-check-input" type="checkbox" name="isActive" checked />
              <label class="form-check-label">ظ…ظپط¹ظ‘ظ„</label>
            </div>
          </div>
        </div>
      </div>
    </form>
  `;
  let bannerImageUploader = null;
  closeModal('b-modal');
  openModal({
    id: 'b-modal',
    title: isEdit ? 'طھط¹ط¯ظٹظ„ ط¨ط§ظ†ط±' : 'ط¥ط¶ط§ظپط© ط¨ط§ظ†ط± ط¬ط¯ظٹط¯',
    bodyHTML, large: true,
    submitText: isEdit ? 'ط­ظپط¸ ط§ظ„طھط¹ط¯ظٹظ„ط§طھ' : 'ط¥ط¶ط§ظپط© ط§ظ„ط¨ط§ظ†ط±',
    onSubmit: async (modalEl) => {
      const form = modalEl.querySelector('#b-form');
      if (!form.checkValidity()) { form.reportValidity(); return false; }
      const data = getFormData(form);
      const images = bannerImageUploader ? bannerImageUploader.getImages() : [];
      if (images.length === 0) { showToast('ط£ط¶ظپ طµظˆط±ط© ظ„ظ„ط¨ط§ظ†ط±', 'error'); return false; }
      const rawImageUrl = images[0];
      const payload = {
        imageUrl: rawImageUrl,
        titleAr: data.titleAr || '',
        titleEn: data.titleEn || '',
        subtitleAr: data.subtitleAr || '',
        subtitleEn: data.subtitleEn || '',
        targetType: data.targetType || 'category',
        targetId: data.targetId || '',
        zone: data.zone || 'header',
        order: Number(data.order) || 0,
        isActive: data.isActive !== false,
      };
      try {
        if (rawImageUrl && !rawImageUrl.startsWith('http')) {
          showToast('ط¬ط§ط±ظٹ ط±ظپط¹ طµظˆط±ط© ط§ظ„ط¨ط§ظ†ط±...', 'info', 2000);
          payload.imageUrl = await uploadImageToStorage(rawImageUrl, 'banners');
        }
        if (isEdit) {
          await update('banners', banner.id, payload);
          Object.assign(banner, payload);
          showToast('طھظ… طھط­ط¯ظٹط« ط§ظ„ط¨ط§ظ†ط±', 'success');
        } else {
          const newId = await add('banners', payload);
          CACHE.banners.push({ id: newId, ...payload, createdAt: new Date() });
          showToast('طھظ…طھ ط¥ط¶ط§ظپط© ط§ظ„ط¨ط§ظ†ط±', 'success');
        }
        renderBannersList();
        return true;
      } catch (e) { showToast('ط®ط·ط£: ' + e.message, 'error'); return false; }
    },
    onShown: (modalEl) => {
      bannerImageUploader = setupImageUploader(modalEl, {
        mode: 'single',
        dropzoneId: 'b-img-dropzone',
        inputId: 'b-img-input',
        previewId: 'b-img-preview',
        existing: isEdit && banner.imageUrl ? [banner.imageUrl] : [],
        maxWidth: 1600, quality: 0.85,
      });
      if (isEdit) {
        setFormData(modalEl.querySelector('#b-form'), {
          titleAr: banner.titleAr || '',
          titleEn: banner.titleEn || '',
          subtitleAr: banner.subtitleAr || '',
          subtitleEn: banner.subtitleEn || '',
          targetType: banner.targetType || 'category',
          targetId: banner.targetId || '',
          zone: banner.zone || 'header',
          order: banner.order || 0,
          isActive: banner.isActive !== false,
        });
      }
    },
  });
}

/* =========================================================
   15) طµظپط­ط© ط§ظ„طھظ‚ظٹظٹظ…ط§طھ (Reviews)
   ========================================================= */

let reviewsState = { search: '', rating: '' };

function renderReviews(container) {
  reviewsState = { search: '', rating: '' };
  container.innerHTML = `
    <div class="page-header">
      <div>
        <h1>ط§ظ„طھظ‚ظٹظٹظ…ط§طھ</h1>
        <p class="page-subtitle">ظ…ط±ط§ط¬ط¹ط© ظˆط­ط°ظپ طھظ‚ظٹظٹظ…ط§طھ ط§ظ„ط¹ظ…ظ„ط§ط، ط¹ظ„ظ‰ ط§ظ„ظ…ظ†طھط¬ط§طھ</p>
      </div>
    </div>
    <div class="filter-bar">
      <div class="search-box"><i class="bi bi-search"></i><input type="text" id="rev-search" placeholder="ط§ط¨ط­ط« ط¨ط§ط³ظ… ط§ظ„ظ…ط³طھط®ط¯ظ… ط£ظˆ ط§ظ„طھط¹ظ„ظٹظ‚ ط£ظˆ ط§ظ„ظ…ظ†طھط¬..." /></div>
      <select class="form-select" id="rev-rating" style="max-width:160px;">
        <option value="all">ظƒظ„ ط§ظ„طھطµظ†ظٹظپط§طھ</option>
        <option value="5">âک…âک…âک…âک…âک… (5)</option>
        <option value="4">âک…âک…âک…âک…âک† (4)</option>
        <option value="3">âک…âک…âک…âک†âک† (3)</option>
        <option value="2">âک…âک…âک†âک†âک† (2)</option>
        <option value="1">âک…âک†âک†âک†âک† (1)</option>
      </select>
    </div>
    <div class="card"><div class="card-body p-0"><div id="rev-list"></div></div></div>
  `;
  $('#rev-search').addEventListener('input', e => { reviewsState.search = e.target.value; renderReviewsList(); });
  $('#rev-rating').addEventListener('change', e => { reviewsState.rating = e.target.value; renderReviewsList(); });
  renderReviewsList();
}

function renderReviewsList() {
  const wrap = $('#rev-list');
  let items = CACHE.reviews.filter(r => {
    const product = CACHE.products.find(p => p.id === r.productId);
    const productName = product?.nameAr || product?.nameEn || '';
    const ms = !reviewsState.search ||
      arabicSearch(r.userName, reviewsState.search) ||
      arabicSearch(r.comment, reviewsState.search) ||
      arabicSearch(productName, reviewsState.search);
    const mr = reviewsState.rating === 'all' || !reviewsState.rating || String(r.rating) === reviewsState.rating;
    return ms && mr;
  });
  if (items.length === 0) {
    wrap.innerHTML = `<div class="empty-state"><i class="bi bi-star"></i><h5>ظ„ط§ طھظˆط¬ط¯ طھظ‚ظٹظٹظ…ط§طھ</h5></div>`;
    return;
  }
  wrap.innerHTML = items.map(r => {
    const product = CACHE.products.find(p => p.id === r.productId);
    const stars = 'âک…'.repeat(r.rating || 0) + 'âک†'.repeat(5 - (r.rating || 0));
    return `
      <div class="review-item d-flex gap-3">
        <div class="avatar-circle">${esc((r.userName || 'ظ…').charAt(0))}</div>
        <div class="flex-grow-1">
          <div class="d-flex justify-content-between">
            <div>
              <strong>${esc(r.userName || 'ظ…ط³طھط®ط¯ظ…')}</strong>
              <span class="review-stars ms-2">${stars}</span>
            </div>
            <small class="text-muted">${formatDate(r.createdAt)}</small>
          </div>
          <p class="mb-1 text-muted">ط¹ظ„ظ‰ ط§ظ„ظ…ظ†طھط¬: <strong>${esc(product?.nameAr || r.productId || 'â€”')}</strong></p>
          <p class="mb-2">${esc(r.comment || 'â€”')}</p>
          <button class="btn btn-sm btn-outline-danger" data-rev-id="${esc(r.id)}"><i class="bi bi-trash me-1"></i> ط­ط°ظپ</button>
        </div>
      </div>
    `;
  }).join('');
  $$('#rev-list [data-rev-id]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const r = CACHE.reviews.find(x => x.id === btn.dataset.revId);
      if (!r) return;
      const ok = await confirmAction('ط³ظٹطھظ… ط­ط°ظپ ظ‡ط°ط§ ط§ظ„طھظ‚ظٹظٹظ… ظ†ظ‡ط§ط¦ظٹظ‹ط§. ظ‡ظ„ ط£ظ†طھ ظ…طھط£ظƒط¯طں', 'ط­ط°ظپ ط§ظ„طھظ‚ظٹظٹظ…', 'ط­ط°ظپ', 'danger');
      if (ok) {
        try {
          await removeReview(r);
          CACHE.reviews = CACHE.reviews.filter(x => x.id !== r.id);
          renderReviewsList();
          showToast('طھظ… ط­ط°ظپ ط§ظ„طھظ‚ظٹظٹظ…', 'success');
        } catch (e) { showToast('ط®ط·ط£: ' + e.message, 'error'); }
      }
    });
  });
}

