function renderSettings(container) {
  const s = CACHE.settings || {};
  container.innerHTML = `
    <div class="page-header">
      <div>
        <h1>ط§ظ„ط¥ط¹ط¯ط§ط¯ط§طھ</h1>
        <p class="page-subtitle">ط¥ط¯ط§ط±ط© ط§ظ„ط¥ط¹ط¯ط§ط¯ط§طھ ط§ظ„ط¹ط§ظ…ط© ظ„ظ„ظ…طھط¬ط±</p>
      </div>
      <div class="page-actions">
        <button class="btn btn-primary" id="btn-save-settings"><i class="bi bi-save me-1"></i> ط­ظپط¸ ط§ظ„ط¥ط¹ط¯ط§ط¯ط§طھ</button>
      </div>
    </div>
    <div id="settings-wrap">
      <div class="row g-3">
        <!-- ظ…ط¹ظ„ظˆظ…ط§طھ ط§ظ„ظ…طھط¬ط± -->
        <div class="col-12">
