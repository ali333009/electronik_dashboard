function openBannerModal(banner = null) {
  const isEdit = !!banner;
  const bodyHTML = `
    <form id="b-form">
      <div class="mb-3">
        <label class="form-label">طµظˆط±ط© ط§ظ„ط¨ط§ظ†ط± <span class="text-danger">*</span></label>
        <div class="image-uploader" id="b-img-dropzone">
          <i class="bi bi-cloud-arrow-up upload-icon"></i>
          <p>ط§ط³ط­ط¨ طµظˆط±ط© ظ‡ظ†ط§ ط£ظˆ ط§ط¶ط؛ط· ظ„ظ„ط§ط®طھظٹط§ط±</p>
          <small>ظٹظڈظپط¶ظ‘ظ„ ط¨ط£ط¨ط¹ط§ط¯ 1200أ—600 ط¨ظƒط³ظ„ â€” ط³ظٹطھظ… طھط­ظˆظٹظ„ظ‡ط§ ط¥ظ„ظ‰ WebP</small>
          <input type="file" id="b-img-input" accept="image/*" hidden />
        </div>
        <div class="image-preview-grid single-image-preview" id="b-img-preview"></div>
      </div>
      <div class="row g-3">
        <div class="col-md-6"><div class="mb-3"><label class="form-label">ط§ظ„ط¹ظ†ظˆط§ظ† (ط¹ط±ط¨ظٹ)</label><input type="text" class="form-control" name="titleAr" /></div></div>
        <div class="col-md-6"><div class="mb-3"><label class="form-label">ط§ظ„ط¹ظ†ظˆط§ظ† (ط¥ظ†ط¬ظ„ظٹط²ظٹ)</label><input type="text" class="form-control" name="titleEn" dir="ltr" /></div></div>
        <div class="col-md-6"><div class="mb-3"><label class="form-label">ط§ظ„ط¹ظ†ظˆط§ظ† ط§ظ„ظپط±ط¹ظٹ (ط¹ط±ط¨ظٹ)</label><input type="text" class="form-control" name="subtitleAr" /></div></div>
        <div class="col-md-6"><div class="mb-3"><label class="form-label">ط§ظ„ط¹ظ†ظˆط§ظ† ط§ظ„ظپط±ط¹ظٹ (ط¥ظ†ط¬ظ„ظٹط²ظٹ)</label><input type="text" class="form-control" name="subtitleEn" dir="ltr" /></div></div>
        <div class="col-md-4">
          <div class="mb-3">
            <label class="form-label">ظ†ظˆط¹ ط§ظ„ظ‡ط¯ظپ</label>
            <select class="form-select" name="targetType">
              <option value="category">ظپط¦ط©</option>
              <option value="product">ظ…ظ†طھط¬</option>
              <option value="url">ط±ط§ط¨ط·</option>
            </select>
